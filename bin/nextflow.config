params {
    // Input parameters
    fastq_dir = null
    ref_fasta = "${projectDir}/../data/refs/GRCh38.fasta"
    ref_fai = "${projectDir}/../data/refs/GRCh38.fasta.fai"
    ref_dict = "${projectDir}/../data/refs/GRCh38.dict"

    // -------------------------------------------------------
    // Aligner Selection: 'bwa-mem' or 'bwa-mem2'
    //   - bwa-mem  : classic BWA-MEM (low memory, ~3GB index)
    //   - bwa-mem2 : ~2x faster, requires ~64GB RAM for index load
    // -------------------------------------------------------
    aligner = 'bwa-mem2'

    // BWA-MEM (classic) index directory
    ref_bwa_indices = "${projectDir}/../data/refs/bwa_index"

    // BWA-MEM2 index directory (must be pre-built; see SERVER_SETUP.md)
    ref_bwa_mem2_indices = "${projectDir}/../data/refs/bwa_mem2_index"

    // -------------------------------------------------------
    // Variant Caller Selection: 'gatk', 'deepvariant', 'strelka2'
    //   - gatk        : HaplotypeCaller + VariantFiltration (hard filter)
    //   - deepvariant : Google DeepVariant CNN model (WES mode, no extra filter needed)
    //   - strelka2    : Illumina Strelka2 (exome mode, fast, no extra filter needed)
    // -------------------------------------------------------
    variant_caller = 'deepvariant'

    // -------------------------------------------------------
    // VEP Annotation (runs after variant calling)
    //   skip_vep = false : run VEP annotation (recommended)
    //   skip_vep = true  : skip VEP (service-daemon will use snpEff fallback)
    //
    // vep_cache_dir: pre-downloaded Ensembl VEP cache directory.
    //   Download command (server, one-time):
    //     vep_install -a cf -s homo_sapiens -y GRCh38 -c /data/refs/vep_cache --CONVERT
    //   Or via Docker:
    //     docker run -v /data/refs/vep_cache:/opt/vep/.vep \
    //       ensemblorg/ensembl-vep:release_111 \
    //       perl INSTALL.pl -a cf -s homo_sapiens -y GRCh38 --CONVERT
    // -------------------------------------------------------
    skip_vep = false
    vep_cache_dir = "${projectDir}/../data/refs/vep_cache"

    // Pre-downloaded RefSeq GTF for PREPARE_VIZ_RESOURCES (avoids runtime UCSC download)
    // Download: wget -O data/refs/hg38.ncbiRefSeq.gtf.gz https://hgdownload.soe.ucsc.edu/goldenPath/hg38/bigZips/genes/hg38.ncbiRefSeq.gtf.gz
    refgene_gtf = "${projectDir}/../data/refs/hg38.ncbiRefSeq.gtf.gz"

    // BED files
    backbone_bed          = "${projectDir}/../data/bed/twist-exome2/targets.bed"
    backbone_bed_gz       = "${projectDir}/../data/bed/twist-exome2/targets.bed.gz"
    backbone_bed_tbi      = "${projectDir}/../data/bed/twist-exome2/targets.bed.gz.tbi"
    dark_genes_plus_bed   = "${projectDir}/../data/bed/dark_genes_plus.bed"
    // DEPTH_ANALYSIS: optional warning when mean depth on dark-gene rows (same as Region table) is below this. Set to 0 to disable.
    depth_warning_min_dark = 15
    // MOSDEPTH_PER_BASE_QC: per-base + tabix under results/qc for service-daemon (no daemon change).
    skip_mosdepth_per_base = false
    // Per-gene TSV (*_gene_coverage.tsv): uses BED column 4 as gene key (HGNC targets for panel disease BED).
    skip_gene_coverage_tsv = false
    // If null, gene TSV uses backbone_bed; override with panel disease BED when capture BED lacks HGNC in col4.
    gene_coverage_bed = null
    // If false, only HBA1_HBA2_Region is used for the threshold (SMN1_SMN2 window mean is often misleading vs panel depth; use Paraphase/SMAca for SMA).
    depth_warning_include_smn = false
    hba_bed               = "${projectDir}/../data/bed/hba_targets.bed"
    // HBA1 vs HBA2 paralog discriminator sites (GRCh38; bundled under bin/modules for container mounts)
    hba_paralog_sites     = "${projectDir}/modules/hba_paralog_sites.tsv"
    // CYP21A2 vs CYP21A1P (GRCh38; regenerate with scripts/extract_cyp21_paralog_sites.py if needed)
    cyp21_paralog_sites   = "${projectDir}/modules/cyp21_paralog_sites.tsv"
    // 0 = all sites; default caps runtime (~777 sites in bundle)
    cyp21_paralog_max_sites = 250
    cyp21_paralog_total_diploid_copies = 2
    // NM_000500.9 CYP21A2 hotspot sites (GRCh38) — screened in summary detailed report from annotated/filtered VCF
    cyp21a2_hotspots      = "${projectDir}/modules/cyp21a2_hotspots.tsv"
    cyp21a2_bed           = "${projectDir}/../data/bed/cyp21a2_targets.bed"

    // CNV / SV
    pon_tar = null // Panel of Normals for GATK gCNV
    eh_catalog = "${projectDir}/../data/bed/variant_catalog_grch38.json"
    gcnv_model = null // Path to GCNV model for Case Mode (skips cohort training)
    interval_list = null

    // SMAca post-process (SMACA_RUN): c.840 pileup + CN split; see bin/modules/pseudogene.nf
    // GRCh38 chr5 (1-based): NM_000344.4 / NM_017411.4 c.840 (Ensembl VEP); was off-by-one vs T-run
    smn_c840_sm1_grch38_1bp = 70951946
    smn_c840_sm2_grch38_1bp = 70076526
    smn_cnv_est_total_copies = 4
    // Unified SMN mini-ref (same slice as PREPARE_VIZ_RESOURCES smn_ref_wide): SMN1+SMN2 reads re-aligned to one SMN1 haplotype; c.840 1bp offset in that ref (smn_c840_sm1_grch38_1bp - start + 1)
    smn_unified_region_start = 70920000
    smn_unified_region_end = 70960000
    smn_unified_c840_pileup_1bp = 31947

    // Switches
    skip_cnv = false

    // Outputs
    outdir = 'results'         // Analysis directory (intermediate files)
    output_dir = null          // Output directory (portal files)
    sample_name = null         // Sample name for tracking

    // Cleanup
    cleanup = false

    // -------------------------------------------------------
    // PGx (PharmCAT) — default on each run; see docs/pgx.md
    // -------------------------------------------------------
    skip_pgx = false
    skip_apoe = false
    // Proactive health: APOE off unless include_apoe true (see main.nf runApoe)
    proactive_health_test = false
    include_apoe = false
    pgx_reference_genome = 'GRCh38'
    pgx_container = 'pgkb/pharmcat:3.2.0'
}

// Enable performance monitoring
trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/trace.txt"
    fields = 'task_id,name,status,exit,realtime,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,cpus,memory'
}
timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/report.html"
}

// CLI `-with-dag log/.../dag.html` fails on reruns unless overwrite is allowed (fresh runs keep log/).
dag {
    enabled = true
    overwrite = true
}

process {
    // -------------------------------------------------------
    // BWA-MEM (classic)
    // -------------------------------------------------------
    withLabel: 'bwa' {
        container = 'quay.io/biocontainers/bwa:0.7.17--hed695b0_7'
        cpus = 16
        memory = '32.GB'
    }

    // -------------------------------------------------------
    // BWA-MEM2 — requires significantly more RAM for index load
    // nf-core mulled image includes bwa-mem2 2.2.1 + samtools 1.15.1
    // -------------------------------------------------------
    withLabel: 'bwa_mem2' {
        container = 'quay.io/biocontainers/mulled-v2-e5d375990341c5aef3c9aff74f96f66f65375ef6:2cdf6bf1e92acbeb9b2834b1c58754167173a410-0'
        cpus = 16
        memory = '64.GB'
    }

    withLabel: 'samtools' {
        container = 'quay.io/biocontainers/samtools:1.16.1--h6899075_1'
        cpus = 8
        memory = '16.GB'
    }

    // -------------------------------------------------------
    // GATK (HaplotypeCaller + VariantFiltration)
    // -------------------------------------------------------
    withLabel: 'gatk' {
        container = 'broadinstitute/gatk:4.4.0.0'
        cpus = 4
        memory = '16.GB'
    }

    // -------------------------------------------------------
    // DeepVariant — WES model_type required (no extra filter needed)
    // -------------------------------------------------------
    withLabel: 'deepvariant' {
        container = 'google/deepvariant:1.6.1'
        cpus = 16
        memory = '32.GB'
    }

    // -------------------------------------------------------
    // Strelka2 — exome mode required for WES (no extra filter needed)
    // -------------------------------------------------------
    withLabel: 'strelka2' {
        container = 'quay.io/biocontainers/strelka:2.9.10--h9ee0642_1'
        cpus = 16
        memory = '16.GB'
    }

    // -------------------------------------------------------
    // VEP (Variant Effect Predictor) — Ensembl official image
    // release_111 supports GRCh38 with gnomAD v4 AF
    // -------------------------------------------------------
    withLabel: 'vep' {
        container = 'ensemblorg/ensembl-vep:release_111.0'
        cpus = 8
        memory = '16.GB'
    }

    withLabel: 'vep_docker' {
        container = 'ensemblorg/ensembl-vep:release_111.0'
        cpus = 8
        memory = '16.GB'
    }

    withLabel: 'manta' {
        container = 'quay.io/biocontainers/manta:1.6.0--h9ee0642_1'
        cpus = 8
        memory = '8.GB'
    }
    withName: 'ALIGN_AND_SORT' {
        cpus = 16
        memory = '32.GB'
    }
    withName: 'ALIGN_AND_SORT_BWA_MEM2' {
        cpus = 16
        memory = '64.GB'
    }
    withName: 'MOSDEPTH_PER_BASE_QC' {
        cpus = 8
        memory = '24.GB'
    }
    withLabel: 'paraphase' {
        container = 'quay.io/biocontainers/paraphase:3.1.0--pyhdfd78af_0'
        memory = '16.GB'
    }
    withLabel: 'smn_unified_c840' {
        container = 'quay.io/biocontainers/mulled-v2-e5d375990341c5aef3c9aff74f96f66f65375ef6:2cdf6bf1e92acbeb9b2834b1c58754167173a410-0'
        cpus = 8
        memory = '16.GB'
    }
    withLabel: 'smaca' {
        container = 'quay.io/biocontainers/smaca:1.2.3--py311hc1104ee_6'
        // Copy staged inputs into work dir — symlinks to /app/bin/... are not resolvable inside this
        // container (only NXF_DATA_DIR is bind-mounted), so python helper must be a real file in work/.
        stageInMode = 'copy'
        memory = '8.GB'
    }
    withLabel: 'expansionhunter' {
        container = 'quay.io/biocontainers/expansionhunter:5.0.0--hc26b3af_5'
        stageInMode = 'copy'
        memory = '8.GB'
    }
    withLabel: 'python' {
        container = 'python:3.9-slim'
    }

    // PREPARE_VIZ_RESOURCES — runs inside the gx-exome image (igv-reports, pysam, bwa, samtools pre-installed)
    withLabel: 'local' {
        container = 'gx-exome:latest'
        cpus = 4
        memory = '8.GB'
    }

    // GENERATE_VISUAL_EVIDENCE — same image with viz tools
    withLabel: 'visualize' {
        container = 'gx-exome:latest'
        cpus = 4
        memory = '16.GB'
    }

    // PharmCAT (CPIC / PharmGKB-backed PGx) — image overridden via params.pgx_container
    withLabel: 'pgx' {
        // Pinned image (avoid params.* here — NF 25 can warn during config eval). Override via process selector or extra config.
        container = 'pgkb/pharmcat:3.2.0'
        cpus = 4
        memory = '8.GB'
    }
    // Aldy CYP2D6 star-allele caller — reuses python:3.12-bookworm (already pulled for pgx_finalize)
    withLabel: 'aldy' {
        container = 'python:3.12-bookworm'
        cpus = 2
        memory = '4.GB'
    }
    // Extended PGx panel — pysam pip-installed at runtime for VCF querying
    // stageInMode = 'copy': symlink targets live in the NF head container (/app/bin/…), not in this image.
    withLabel: 'pgx_custom' {
        container = 'python:3.12-bookworm'
        stageInMode = 'copy'
        cpus = 2
        memory = '4.GB'
    }
    // APOE rs429358/rs7412 — same pysam pattern as pgx_custom
    withLabel: 'apoe' {
        container = 'python:3.12-bookworm'
        stageInMode = 'copy'
        cpus = 2
        memory = '4.GB'
    }
    // pgx_finalize.py — PharmCAT image may not ship python3 on PATH; run finalizer in Python Bookworm.
    // Use non-slim image: Nextflow 25+ runs `ps` in the container for task metrics; python:*-slim omits procps.
    // stageInMode = 'copy': symlink targets live in the NF head container (/app/bin/…), not in this image.
    withLabel: 'pgx_finalize' {
        container = 'python:3.12-bookworm'
        stageInMode = 'copy'
        cpus = 1
        memory = '2.GB'
    }
}

profiles {
    docker {
        docker.enabled = true
        docker.remove = true
        // NXF_DATA_DIR is set in run_analysis.sh so the host Docker daemon
        // mounts the project root into every task container.
        // NXF_DOCKER_TASK_USER (e.g. 1000:1000) runs task containers as that uid:gid so bind-mounted
        // outputs match the host user. The Nextflow *head* JVM must create work/ as the same uid
        // (run_analysis.sh runs gx-exome with -u CHOWN_SPEC); otherwise task containers get
        // "touch: .command.trace: Permission denied" on root-owned work hash dirs.
        // If unset, task containers fall back to root (legacy; host dirs may need post-run chown).
        // NXF_DATA_DIR mount: lets task containers access staged symlinks from data/refs/ and data/bed/.
        // /data/reference is NOT added here — Nextflow auto-mounts it by resolving real paths of
        //   staged path inputs (e.g. GRCh38.fasta → data/refs/GRCh38.fasta → /data/reference/...).
        //   Adding it manually would cause "Duplicate mount point" errors.
        def nxfTaskUser = System.getenv('NXF_DOCKER_TASK_USER')
        def dockerUserOpt = (nxfTaskUser != null && !nxfTaskUser.trim().isEmpty()) ? "--user ${nxfTaskUser}" : '--user root'
        def nxfDataDir = System.getenv('NXF_DATA_DIR')
        if (nxfDataDir == null || nxfDataDir.trim().isEmpty()) {
            throw new RuntimeException("NXF_DATA_DIR environment variable is not set. It is required by the docker profile to mount the project root into task containers.")
        }
        docker.runOptions = "--platform linux/amd64 ${dockerUserOpt} -v ${nxfDataDir}:${nxfDataDir}"
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
}
