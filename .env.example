# ============================================================
# Carrier Screening Pipeline - Environment Configuration
# ============================================================

# --- Pipeline Directories ---
DATA_DIR=/data
REF_DIR=/data/refs
BED_DIR=/data/bed
MODELS_DIR=/data/models

# --- service-daemon (별도 레포 / 별도 compose) ---
# 이 carrier_screening/docker-compose.yml에서는 사용하지 않습니다.
# genolyx/service-daemon 레포의 .env에서 설정하세요.
# SERVICE_DAEMON_DIR=../../service-daemon

# --- Platform API (Optional) ---
# service-daemon 등에서 업로드 시 사용
PLATFORM_API_URL=https://platform.genolyx.com/api/v1
PLATFORM_API_KEY=your_platform_api_key_here

# --- Annotation Databases ---
# ClinVar VCF (download from NCBI FTP)
CLINVAR_VCF=/data/annotation/clinvar

# gnomAD directory (per-chromosome VCFs)
GNOMAD_DIR=/data/annotation/gnomad

# HGMD Professional VCF (requires license)
HGMD_VCF=/data/annotation/hgmd

# --- Pipeline Execution ---
# Nextflow JVM options
NXF_OPTS=-Xms1g -Xmx4g

# Docker profile (docker or singularity)
NXF_PROFILE=docker
